{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-3.5-flash",
    "api_key_env": "GOOGLE_API_KEY",
    "languages": ["pt_BR"],
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "EdSurge (EdTech)",
        "url": "https://www.edsurge.com/articles_rss",
        "enabled": true,
        "category": "edtech"
      },
      {
        "name": "eSchool News",
        "url": "https://www.eschoolnews.com/feed/",
        "enabled": true,
        "category": "edtech"
      },
      {
        "name": "Free Tech 4 Teachers",
        "url": "https://feeds.feedburner.com/freetech4teachers",
        "enabled": true,
        "category": "edtech"
      },
      {
        "name": "The Edublogger",
        "url": "https://www.theedublogger.com/feed/",
        "enabled": true,
        "category": "edtech"
      },
      {
        "name": "Hack Education",
        "url": "http://hackeducation.com/feed.xml",
        "enabled": true,
        "category": "edtech"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "androiddev",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 20
        },
        {
          "subreddit": "Localfirst",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 5,
          "min_score": 5
        },
        {
          "subreddit": "edtech",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 5,
          "min_score": 5
        },
        {
          "subreddit": "opensource",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 20
        }
      ],
      "users": [],
      "fetch_comments": 5
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24
  }
}
